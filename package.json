{
  "name": "luogu-vscode-ide",
  "displayName": "洛谷 IDE",
  "description": "在 VSCode 中浏览洛谷题库、查看题目详情、编写代码并本地运行测试",
  "version": "1.0.0",
  "publisher": "gunhun4018",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "luogu-sidebar",
          "title": "洛谷",
          "icon": "resources/luogu.svg"
        }
      ]
    },
    "views": {
      "luogu-sidebar": [
        {
          "id": "luogu-problem-list",
          "name": "题库",
          "type": "webview",
          "icon": "resources/luogu.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "luogu.openProblem",
        "title": "洛谷: 打开题目"
      },
      {
        "command": "luogu.openIDE",
        "title": "洛谷: 打开 IDE"
      },
      {
        "command": "luogu.refreshProblemList",
        "title": "洛谷: 刷新题库列表",
        "icon": "$(refresh)"
      },
      {
        "command": "luogu.openBrowser",
        "title": "洛谷: 打开洛谷网站",
        "icon": "$(globe)"
      },
      {
        "command": "luogu.openSettings",
        "title": "洛谷: 打开设置",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "luogu.refreshProblemList",
          "when": "view == luogu-problem-list",
          "group": "navigation@1"
        },
        {
          "command": "luogu.openBrowser",
          "when": "view == luogu-problem-list",
          "group": "navigation@2"
        },
        {
          "command": "luogu.openSettings",
          "when": "view == luogu-problem-list",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "洛谷 IDE",
      "properties": {
        "luogu.defaultLanguage": {
          "type": "string",
          "default": "cpp",
          "enum": [
            "c",
            "cpp",
            "java",
            "python3",
            "pascal"
          ],
          "enumDescriptions": [
            "C",
            "C++",
            "Java",
            "Python 3",
            "Pascal"
          ],
          "description": "默认编程语言"
        },
        "luogu.runTimeout": {
          "type": "number",
          "default": 5000,
          "description": "运行超时时间（毫秒）"
        },
        "luogu.autoOpenIDE": {
          "type": "boolean",
          "default": true,
          "description": "在网站浏览模式中，检测到题目页面时自动打开本地 IDE"
        },
        "luogu.defaultProblemType": {
          "type": "string",
          "default": "P",
          "enum": [
            "P",
            "CF",
            "SP",
            "AT",
            "UVA"
          ],
          "enumDescriptions": [
            "洛谷",
            "Codeforces",
            "SPOJ",
            "AtCoder",
            "UVa"
          ],
          "description": "默认题库类型"
        },
        "luogu.cppCompiler": {
          "type": "string",
          "default": "g++",
          "description": "C++ 编译器路径或名称"
        },
        "luogu.cCompiler": {
          "type": "string",
          "default": "gcc",
          "description": "C 编译器路径或名称"
        },
        "luogu.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python 解释器路径或名称"
        },
        "luogu.cppStandard": {
          "type": "string",
          "default": "c++14",
          "enum": [
            "c++11",
            "c++14",
            "c++17",
            "c++20"
          ],
          "description": "C++ 标准版本"
        },
        "luogu.compileArgs": {
          "type": "string",
          "default": "-O2",
          "description": "额外编译参数"
        },
        "luogu.problemsPerPage": {
          "type": "number",
          "default": 50,
          "description": "每页显示题目数量（由服务器决定，仅供参考）"
        }
      }
    }
  },
  "scripts": {
  "vscode:prepublish": "npm run build",
  "compile": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
  "build": "npm run compile",
  "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^5.0.1",
    "markdown-it": "^14.1.1",
    "node-fetch": "^2.7.0"
  }
}
